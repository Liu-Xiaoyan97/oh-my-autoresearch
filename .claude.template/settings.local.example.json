{
  "ssh": {
    "chain": [
      {
        "host": "jump.example.com",
        "port": 22,
        "user": "your_username",
        "keyPath": "~/.ssh/id_rsa"
      },
      {
        "host": "gpu-node.example.com",
        "port": 22,
        "user": "your_username",
        "keyPath": "~/.ssh/id_rsa"
      }
    ]
  },

  "observer": {
    "pollInterval": 5
  },

  "training": {
    "maxTimeout": 86400
  },

  "debug": {
    "skipRemoteValidation": false,
    "verboseLogging": false
  }
}
