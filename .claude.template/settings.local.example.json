// settings.local.example.json - 本机私有设置样例
// 复制为 settings.local.json 并修改后使用
// 此文件不会被 install.sh 安装

{
  // SSH 链式跳转主机配置 (远程训练时使用)
  "ssh": {
    "chain": [
      {
        "host": "jump.example.com",
        "port": 22,
        "user": "your_username",
        "keyPath": "~/.ssh/id_rsa"
      },
      {
        "host": "gpu-node.example.com",
        "port": 22,
        "user": "your_username",
        "keyPath": "~/.ssh/id_rsa"
      }
    ]
  },

  // Observer 轮询间隔 (秒)
  "observer": {
    "pollInterval": 5
  },

  // 训练超时时间 (秒)，超过则自动终止
  "training": {
    "maxTimeout": 86400
  },

  // 本地调试模式 (跳过 remote 校验)
  "debug": {
    "skipRemoteValidation": false,
    "verboseLogging": false
  }
}
