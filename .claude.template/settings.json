{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "300000"
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop.sh" } ] }
    ]
  },
  "permissions": {
    "policy": "strict",
    "_comment": "主程序(team-lead)工具白名单。team-lead 无任何直接写权：不含 Write/Edit/MultiEdit/NotebookEdit。所有日志/数据库/状态写入都通过 observer event 落盘。代码文件由 coder subagent 负责写(coder 有自己的工具继承，不受此主程序白名单约束)。",
    "allowed": [
      "Bash",
      "Read",
      "Grep",
      "Glob",
      "Agent",
      "CronCreate",
      "CronList",
      "CronDelete",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Codegraph"
    ],
    "denied": [
      "Shell",
      "TaskCreate",
      "TaskUpdate",
      "Write",
      "Edit",
      "MultiEdit",
      "NotebookEdit"
    ],
    "defaultMode": "bypassPermissions"
  },
  "observer": {
    "lifecycle": {
      "startHook": ".claude/hooks/session-start.sh",
      "stopHook": ".claude/hooks/stop.sh",
      "healthcheckScript": "runtime/observer/scripts/lifecycle/healthcheck.sh"
    }
  }
}
