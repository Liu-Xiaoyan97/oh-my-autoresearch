{
  "hooks": {
    "onSessionStart": ".claude/hooks/session-start.sh",
    "onSessionStop": ".claude/hooks/stop.sh",
    "onToolUse": {
      "pre": ".claude/hooks/pre-tool-use.sh",
      "post": ".claude/hooks/post-tool-use.sh"
    }
  },
  "permissions": {
    "policy": "strict",
    "allowed": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Agent",
      "CronCreate",
      "CronList",
      "CronDelete",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Codegraph"
    ],
    "denied": [
      "Shell",
      "TaskCreate",
      "TaskUpdate"
    ]
  },
  "observer": {
    "lifecycle": {
      "startHook": ".claude/hooks/session-start.sh",
      "stopHook": ".claude/hooks/stop.sh",
      "healthcheckScript": "runtime/observer/scripts/lifecycle/healthcheck.sh"
    }
  }
}
