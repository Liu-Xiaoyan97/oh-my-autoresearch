{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop.sh" } ] }
    ],
    "PreToolUse": [
      { "matcher": "", "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool-use.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "", "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-tool-use.sh" } ] }
    ]
  },
  "permissions": {
    "policy": "strict",
    "allowed": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Agent",
      "CronCreate",
      "CronList",
      "CronDelete",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Codegraph"
    ],
    "denied": [
      "Shell",
      "TaskCreate",
      "TaskUpdate"
    ]
  },
  "observer": {
    "lifecycle": {
      "startHook": ".claude/hooks/session-start.sh",
      "stopHook": ".claude/hooks/stop.sh",
      "healthcheckScript": "runtime/observer/scripts/lifecycle/healthcheck.sh"
    }
  }
}
