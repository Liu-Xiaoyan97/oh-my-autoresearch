{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tool Result",
  "description": "team-lead 调用 runtime scripts 或工具后的统一结果格式",
  "type": "object",
  "required": ["command", "exit_code", "status"],
  "properties": {
    "command": {
      "type": "string",
      "description": "执行的命令"
    },
    "exit_code": {
      "type": "integer",
      "description": "退出码"
    },
    "stdout": {
      "type": "string",
      "description": "标准输出"
    },
    "stderr": {
      "type": "string",
      "description": "标准错误"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "timeout"],
      "description": "执行状态"
    },
    "parsed_payload": {
      "type": ["object", "null"],
      "description": "解析后的负载"
    }
  }
}
