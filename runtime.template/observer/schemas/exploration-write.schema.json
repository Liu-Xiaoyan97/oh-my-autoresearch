{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exploration Write Schema",
  "description": "约束写入 exploration 表的事件 payload",
  "type": "object",
  "required": ["action", "exp_name"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["insert_exploration", "update_orthogonal_candidates", "update_decision", "update_commit"]
    },
    "exp_name": { "type": "string" },
    "data": {
      "type": "object",
      "properties": {
        "orthogonal_direction_scout": { "type": ["object", "null"] },
        "decision": { "type": ["object", "null"] },
        "commit_id": { "type": ["string", "null"] }
      }
    }
  }
}
