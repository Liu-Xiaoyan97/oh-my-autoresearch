{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Patch Plan",
  "description": "约束 coder 生成的修改计划",
  "type": "object",
  "required": ["changes"],
  "properties": {
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "action": { "type": "string", "enum": ["modify", "create", "delete"] },
          "description": { "type": "string" }
        }
      }
    }
  }
}
