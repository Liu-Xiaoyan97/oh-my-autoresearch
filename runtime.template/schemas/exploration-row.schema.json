{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exploration Row Schema",
  "description": "约束 exploration 表单行数据结构：4 列，exp_name(PK) 与三个 TEXT 列。",
  "type": "object",
  "required": ["exp_name"],
  "properties": {
    "exp_name": { "type": "string" },
    "orthogonal-direction-scout": { "type": ["string", "null"] },
    "decision": { "type": ["string", "null"] },
    "commit": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
