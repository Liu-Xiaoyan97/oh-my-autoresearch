{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Baseline Schema",
  "description": "约束 runtime/knowledges/baseline.json",
  "type": "object",
  "required": ["method", "primary_metric"],
  "properties": {
    "method": { "type": "string" },
    "architecture": { "type": "string" },
    "command": { "type": "string" },
    "devices": { "type": "array", "items": { "type": "string" } },
    "primary_metric": {
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number" }
      }
    },
    "training_steps": { "type": "integer" },
    "notes": { "type": "string" }
  }
}
