{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Validation Result Schema",
  "description": "约束 Phase 0 runtime validation 返回结果",
  "type": "object",
  "required": ["pass", "checks"],
  "properties": {
    "pass": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
