{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Error Schema",
  "description": "统一错误结构",
  "type": "object",
  "required": ["code", "message"],
  "properties": {
    "code": { "type": "string" },
    "message": { "type": "string" },
    "details": { "type": ["object", "null"] },
    "timestamp": { "type": "string" }
  }
}
