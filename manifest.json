{
  "name": "research-loop-agent",
  "version": "0.1.0",
  "description": "Claude Code research loop agent submodule for automated neural architecture research",
  "claude_template": {
    "source": ".claude.template/",
    "target": ".claude/",
    "files": [
      "CLAUDE.md",
      "settings.json",
      "settings.local.example.json",
      "commands/loop.md",
      "commands/loop-status.md",
      "commands/loop-recover.md",
      "commands/loop-reset.md",
      "commands/loop-doctor.md",
      "agents/orthogonal-direction-scout.md",
      "agents/summarizer.md",
      "agents/coder.md",
      "agents/flow-arch-reviewer.md",
      "agents/math-theorist.md",
      "agents/numerical-debugger.md",
      "schemas/phase0-validation.schema.json",
      "schemas/phase1-exploration.schema.json",
      "schemas/phase3-training.schema.json",
      "schemas/phase9-recovery.schema.json",
      "schemas/state-transition.schema.json",
      "schemas/subagent-result.schema.json",
      "schemas/tool-result.schema.json",
      "scripts/emit_log_event.sh",
      "scripts/call_runtime_script.sh",
      "scripts/validate_subagent_result.py",
      "hooks/session-start.sh",
      "hooks/stop.sh",
      "hooks/pre-tool-use.sh",
      "hooks/post-tool-use.sh"
    ]
  },
  "runtime_template": {
    "source": "runtime.template/",
    "target": "runtime/",
    "files": [
      "states/states.json",
      "states/objective.example.json",
      "knowledges/baseline.json",
      "knowledges/learned.json",
      "knowledges/rejected.json",
      "schemas/state.schema.json",
      "schemas/objective.schema.json",
      "schemas/baseline.schema.json",
      "schemas/learned.schema.json",
      "schemas/rejected.schema.json",
      "schemas/experiment-row.schema.json",
      "schemas/exploration-row.schema.json",
      "schemas/validation-result.schema.json",
      "schemas/training-progress.schema.json",
      "schemas/final-metrics.schema.json",
      "schemas/recovery-result.schema.json",
      "schemas/error.schema.json",
      "observer/config.json",
      "observer/events/.gitkeep",
      "observer/run/.gitkeep",
      "observer/offsets/.gitkeep",
      "observer/schemas/log-event.schema.json",
      "observer/schemas/experiments-write.schema.json",
      "observer/schemas/exploration-write.schema.json",
      "observer/schemas/knowledge-write.schema.json",
      "observer/scripts/lifecycle/start_observer.sh",
      "observer/scripts/lifecycle/stop_observer.sh",
      "observer/scripts/lifecycle/restart_observer.sh",
      "observer/scripts/lifecycle/healthcheck.sh",
      "observer/scripts/ingest/emit_event.py",
      "observer/scripts/ingest/append_event.py",
      "observer/scripts/validate/validate_log_event.py",
      "observer/scripts/validate/validate_experiments_write.py",
      "observer/scripts/validate/validate_exploration_write.py",
      "observer/scripts/validate/validate_knowledge_write.py",
      "observer/scripts/dispatch/observer_daemon.py",
      "observer/scripts/dispatch/consume_events.py",
      "observer/scripts/dispatch/dispatch_event.py",
      "observer/scripts/dispatch/load_offset.py",
      "observer/scripts/dispatch/save_offset.py",
      "observer/scripts/dispatch/write_deadletter.py",
      "observer/scripts/writers/write_log.py",
      "observer/scripts/writers/write_experiments.py",
      "observer/scripts/writers/write_exploration.py",
      "observer/scripts/writers/write_knowledge.py",
      "observer/scripts/writers/write_state.py",
      "agents/orthogonal-direction-scout/schemas/input.schema.json",
      "agents/orthogonal-direction-scout/schemas/reviewer-proposal.schema.json",
      "agents/orthogonal-direction-scout/schemas/candidate.schema.json",
      "agents/orthogonal-direction-scout/schemas/orthogonal-set.schema.json",
      "agents/summarizer/schemas/vote-input.schema.json",
      "agents/summarizer/schemas/vote.schema.json",
      "agents/summarizer/schemas/decision.schema.json",
      "agents/summarizer/schemas/recovery-analysis.schema.json",
      "agents/summarizer/schemas/recovery-summary.schema.json",
      "agents/coder/schemas/coding-task.schema.json",
      "agents/coder/schemas/patch-plan.schema.json",
      "agents/coder/schemas/smoke-test.schema.json",
      "agents/coder/schemas/launch-script.schema.json",
      "agents/coder/schemas/commit-result.schema.json",
      "agents/flow-arch-reviewer/schemas/proposal.schema.json",
      "agents/flow-arch-reviewer/schemas/vote.schema.json",
      "agents/flow-arch-reviewer/schemas/recovery.schema.json",
      "agents/math-theorist/schemas/proposal.schema.json",
      "agents/math-theorist/schemas/vote.schema.json",
      "agents/math-theorist/schemas/recovery.schema.json",
      "agents/numerical-debugger/schemas/proposal.schema.json",
      "agents/numerical-debugger/schemas/vote.schema.json",
      "agents/numerical-debugger/schemas/recovery.schema.json",
      "scripts/validate/validate_schema.py",
      "scripts/validate/validate_states.py",
      "scripts/validate/validate_objective.py",
      "scripts/validate/validate_baseline.py",
      "scripts/validate/validate_runtime.py",
      "scripts/validate/validate_remote.py",
      "scripts/validate/validate_db_schema.py",
      "scripts/database/init_db.py",
      "scripts/database/schema_spec.py",
      "scripts/database/query_tables.py",
      "scripts/database/ensure_experiment_row.py",
      "scripts/database/update_experiment_metric.py",
      "scripts/database/ensure_exploration_row.py",
      "scripts/database/update_exploration_field.py",
      "scripts/git/check_clean.sh",
      "scripts/git/latest_commit.sh",
      "scripts/git/sync_remote.sh",
      "scripts/training/generate_launch.sh",
      "scripts/training/generate_remote.sh",
      "scripts/training/start_training.sh",
      "scripts/training/monitor_training.py",
      "scripts/training/parse_train_log.py",
      "scripts/training/terminate_training.sh",
      "scripts/coding/smoke_test.sh",
      "scripts/coding/create_train_log.sh",
      "scripts/coding/commit_changes.sh",
      "scripts/utils/atomic_write.py",
      "scripts/utils/file_lock.py",
      "scripts/utils/load_json.py",
      "scripts/utils/save_json.py",
      "scripts/utils/jsonl.py",
      "scripts/utils/path_resolve.py",
      "scripts/utils/ssh_chain.py"
    ]
  },
  "install_targets": {
    "claude_target": ".claude/",
    "runtime_target": "runtime/",
    "pyproject_target": "pyproject.toml"
  },
  "supported_commands": [
    "/loop",
    "/loop-status",
    "/loop-recover",
    "/loop-reset",
    "/loop-doctor"
  ],
  "observer_lifecycle_hooks": {
    "start": ".claude.template/hooks/session-start.sh",
    "stop": ".claude.template/hooks/stop.sh"
  },
  "compatible_runtime_version": "0.1.0"
}