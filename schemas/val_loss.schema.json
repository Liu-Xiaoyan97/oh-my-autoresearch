{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Val Loss Index",
  "type": "object",
  "required": ["metric", "mode", "records"],
  "properties": {
    "metric": {
      "type": "string",
      "const": "val_loss"
    },
    "mode": {
      "type": "string",
      "const": "minimize"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "exp_name",
          "iteration",
          "best_val_loss",
          "final_val_loss",
          "best_epoch",
          "status"
        ],
        "properties": {
          "exp_name": {
            "type": "string"
          },
          "iteration": {
            "type": "integer"
          },
          "best_val_loss": {
            "type": ["number", "null"]
          },
          "final_val_loss": {
            "type": ["number", "null"]
          },
          "best_epoch": {
            "type": ["integer", "null"]
          },
          "status": {
            "type": "string",
            "enum": ["queued", "running", "succeeded", "failed", "cancelled"]
          },
          "updated_at": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
