{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase B AgentTeam Output",
  "type": "object",
  "required": [
    "candidate_directions",
    "deduplicated_directions",
    "selected_direction",
    "modification_plan"
  ],
  "properties": {
    "candidate_directions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate_direction"
      }
    },
    "deduplicated_directions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/deduplicated_direction"
      }
    },
    "selected_direction": {
      "$ref": "#/$defs/selected_direction"
    },
    "modification_plan": {
      "$ref": "#/$defs/modification_plan"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "candidate_direction": {
      "type": "object",
      "required": [
        "source",
        "title",
        "rationale",
        "implementation_hint",
        "historical_overlap_risk",
        "expected_risk"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "implementation_hint": {
          "type": "string",
          "minLength": 1
        },
        "historical_overlap_risk": {
          "$ref": "#/$defs/risk_level"
        },
        "expected_risk": {
          "$ref": "#/$defs/risk_level"
        }
      },
      "additionalProperties": true
    },
    "deduplicated_direction": {
      "type": "object",
      "required": [
        "title",
        "merged_from",
        "rationale",
        "implementation_hint",
        "historical_overlap_risk",
        "expected_risk"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "merged_from": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "implementation_hint": {
          "type": "string",
          "minLength": 1
        },
        "historical_overlap_risk": {
          "$ref": "#/$defs/risk_level"
        },
        "expected_risk": {
          "$ref": "#/$defs/risk_level"
        }
      },
      "additionalProperties": true
    },
    "selected_direction": {
      "type": "object",
      "required": [
        "title",
        "rationale",
        "expected_val_loss_effect",
        "risk"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "expected_val_loss_effect": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "$ref": "#/$defs/risk_level"
        }
      },
      "additionalProperties": true
    },
    "modification_plan": {
      "type": "object",
      "required": [
        "status",
        "selected_direction",
        "implementation_scope",
        "files_to_modify",
        "local_validation_commands",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "ready_for_implementation"
        },
        "selected_direction": {
          "type": "string",
          "minLength": 1
        },
        "implementation_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_to_modify": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "local_validation_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
