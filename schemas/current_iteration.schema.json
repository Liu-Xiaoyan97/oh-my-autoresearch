{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Current Iteration",
  "type": "object",
  "required": [
    "exp_name",
    "iteration",
    "agentteam",
    "local_validation",
    "remote_training",
    "result"
  ],
  "properties": {
    "exp_name": {
      "type": ["string", "null"]
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "objective_summary": {
      "type": ["string", "null"]
    },
    "selected_direction": {
      "type": ["string", "null"]
    },
    "candidate_directions": {
      "type": "array"
    },
    "deduplicated_directions": {
      "type": "array"
    },
    "modification_plan": {
      "type": ["string", "null"]
    },
    "code_change_summary": {
      "type": ["string", "null"]
    },
    "agentteam": {
      "type": "object",
      "required": [
        "b1_candidate_review",
        "b2_orthogonality_review",
        "b3_plan_selection",
        "f1_evidence_review"
      ],
      "properties": {
        "b1_candidate_review": {
          "type": "object",
          "required": ["status", "agents", "team_lifecycle", "summary", "candidate_count", "blocking_issues"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "in_progress", "complete", "blocked", "skipped"]
            },
            "agents": {
              "type": "array",
              "const": ["team-leader", "math-theorist", "numerical-debugger", "flow-arch-reviewer"]
            },
            "team_lifecycle": {
              "$ref": "#/$defs/b1_b3_f1_team_lifecycle"
            },
            "summary": {
              "type": ["string", "null"]
            },
            "candidate_count": {
              "type": "integer",
              "minimum": 0
            },
            "blocking_issues": {
              "type": "array"
            }
          }
        },
        "b2_orthogonality_review": {
          "type": "object",
          "required": ["status", "agent", "agents", "team_lifecycle", "summary", "accepted_candidates", "rejected_candidates", "override_reason"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "in_progress", "complete", "blocked", "skipped"]
            },
            "agent": {
              "type": "string",
              "const": "orthogonal-direction-scout"
            },
            "agents": {
              "type": "array",
              "const": ["team-leader", "orthogonal-direction-scout"]
            },
            "team_lifecycle": {
              "$ref": "#/$defs/b2_team_lifecycle"
            },
            "summary": {
              "type": ["string", "null"]
            },
            "accepted_candidates": {
              "type": "array"
            },
            "rejected_candidates": {
              "type": "array"
            },
            "override_reason": {
              "type": ["string", "null"]
            }
          }
        },
        "b3_plan_selection": {
          "type": "object",
          "required": [
            "status",
            "agents",
            "team_lifecycle",
            "selected_candidate",
            "summary",
            "implementation_risks",
            "diagnostic_requirements"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "in_progress", "complete", "blocked", "skipped"]
            },
            "agents": {
              "type": "array",
              "const": ["team-leader", "math-theorist", "numerical-debugger", "flow-arch-reviewer"]
            },
            "team_lifecycle": {
              "$ref": "#/$defs/b1_b3_f1_team_lifecycle"
            },
            "selected_candidate": {
              "type": ["string", "null"]
            },
            "summary": {
              "type": ["string", "null"]
            },
            "implementation_risks": {
              "type": "array"
            },
            "diagnostic_requirements": {
              "type": "array"
            }
          }
        },
        "f1_evidence_review": {
          "type": "object",
          "required": ["status", "agents", "team_lifecycle", "summary", "verdict", "missing_evidence"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "in_progress", "complete", "blocked", "skipped"]
            },
            "agents": {
              "type": "array",
              "const": ["team-leader", "math-theorist", "numerical-debugger", "flow-arch-reviewer"]
            },
            "team_lifecycle": {
              "$ref": "#/$defs/b1_b3_f1_team_lifecycle"
            },
            "summary": {
              "type": ["string", "null"]
            },
            "verdict": {
              "type": ["string", "null"],
              "enum": ["learned", "rejected", "inconclusive", null]
            },
            "missing_evidence": {
              "type": "array"
            }
          }
        }
      }
    },
    "local_validation": {
      "type": "object",
      "required": ["status", "commands", "passed", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "passed", "failed", "skipped"]
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "passed": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "remote_training": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "queued", "running", "succeeded", "failed", "cancelled"]
        },
        "server": {
          "type": ["string", "null"]
        },
        "remote_dir": {
          "type": ["string", "null"]
        },
        "train_command": {
          "type": ["string", "null"]
        },
        "cron_id": {
          "type": ["string", "null"]
        },
        "log_path": {
          "type": ["string", "null"]
        },
        "started_at": {
          "type": ["string", "null"]
        },
        "ended_at": {
          "type": ["string", "null"]
        }
      }
    },
    "result": {
      "type": "object",
      "required": ["status", "best_val_loss", "final_val_loss", "best_epoch", "is_new_best"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "succeeded", "failed", "cancelled"]
        },
        "best_val_loss": {
          "type": ["number", "null"]
        },
        "final_val_loss": {
          "type": ["number", "null"]
        },
        "best_epoch": {
          "type": ["integer", "null"]
        },
        "is_new_best": {
          "type": "boolean"
        }
      }
    },
    "root_cause_analysis": {
      "type": "object",
      "required": ["status", "agent_votes", "verdict", "summary"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "complete", "skipped"]
        },
        "agent_votes": {
          "type": "array"
        },
        "verdict": {
          "type": ["string", "null"],
          "enum": ["learned", "rejected", "inconclusive", null]
        },
        "summary": {
          "type": ["string", "null"]
        }
      }
    },
    "updated_at": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "b1_b3_f1_team_lifecycle": {
      "type": "object",
      "required": [
        "required_agents",
        "completed_agents",
        "all_agents_completed",
        "team_leader_finalized",
        "team_disbanded",
        "disbanded_at",
        "notes"
      ],
      "properties": {
        "required_agents": {
          "type": "array",
          "const": ["team-leader", "math-theorist", "numerical-debugger", "flow-arch-reviewer"]
        },
        "completed_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "all_agents_completed": {
          "type": "boolean"
        },
        "team_leader_finalized": {
          "type": "boolean"
        },
        "team_disbanded": {
          "type": "boolean"
        },
        "disbanded_at": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "b2_team_lifecycle": {
      "type": "object",
      "required": [
        "required_agents",
        "completed_agents",
        "all_agents_completed",
        "team_leader_finalized",
        "team_disbanded",
        "disbanded_at",
        "notes"
      ],
      "properties": {
        "required_agents": {
          "type": "array",
          "const": ["team-leader", "orthogonal-direction-scout"]
        },
        "completed_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "all_agents_completed": {
          "type": "boolean"
        },
        "team_leader_finalized": {
          "type": "boolean"
        },
        "team_disbanded": {
          "type": "boolean"
        },
        "disbanded_at": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
