{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Record",
  "type": "object",
  "required": [
    "exp_name",
    "iteration",
    "created_at",
    "status",
    "phase",
    "objective_summary",
    "selected_direction",
    "candidate_directions",
    "deduplicated_directions",
    "modification_plan",
    "code_change_summary",
    "local_validation",
    "remote_training",
    "metrics",
    "notes"
  ],
  "properties": {
    "exp_name": {
      "type": "string",
      "minLength": 1
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "succeeded", "failed", "cancelled"]
    },
    "phase": {
      "type": "string",
      "enum": ["E", "F"]
    },
    "objective_summary": {
      "type": ["string", "null"]
    },
    "selected_direction": {
      "type": ["string", "null"]
    },
    "candidate_directions": {
      "type": "array"
    },
    "deduplicated_directions": {
      "type": "array"
    },
    "modification_plan": {
      "type": ["string", "null"]
    },
    "code_change_summary": {
      "type": ["string", "null"]
    },
    "local_validation": {
      "type": "object",
      "required": ["status", "commands", "passed", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "passed", "failed", "skipped"]
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "passed": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "remote_training": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "queued", "running", "succeeded", "failed", "cancelled"]
        },
        "server": {
          "type": ["string", "null"]
        },
        "remote_dir": {
          "type": ["string", "null"]
        },
        "train_command": {
          "type": ["string", "null"]
        },
        "cron_id": {
          "type": ["string", "null"]
        },
        "log_path": {
          "type": ["string", "null"]
        },
        "started_at": {
          "type": ["string", "null"]
        },
        "ended_at": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "required": [
        "best_val_loss",
        "final_val_loss",
        "best_epoch",
        "loss_curve"
      ],
      "properties": {
        "best_val_loss": {
          "type": ["number", "null"]
        },
        "final_val_loss": {
          "type": ["number", "null"]
        },
        "best_epoch": {
          "type": ["integer", "null"]
        },
        "loss_curve": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "epoch": {
                "type": "integer",
                "minimum": 0
              },
              "val_loss": {
                "type": "number"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
