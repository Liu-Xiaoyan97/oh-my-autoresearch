{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Objective",
  "type": "object",
  "required": [
    "goal",
    "primary_metric",
    "success_criteria",
    "stop_conditions",
    "constraints",
    "exploration_policy"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "primary_metric": {
      "type": "object",
      "required": ["name", "mode"],
      "properties": {
        "name": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["minimize", "maximize"]
        }
      }
    },
    "success_criteria": {
      "type": "object"
    },
    "stop_conditions": {
      "type": "object",
      "required": [
        "max_iterations",
        "no_improvement_patience",
        "reach_target_metric",
        "manual_stop"
      ],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "no_improvement_patience": {
          "type": "integer",
          "minimum": 1
        },
        "reach_target_metric": {
          "type": "boolean"
        },
        "manual_stop": {
          "type": "boolean"
        }
      }
    },
    "constraints": {
      "type": "object"
    },
    "exploration_policy": {
      "type": "object"
    }
  }
}